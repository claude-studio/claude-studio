{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/cache/local/claude-studio/1.0.0/hooks/notify.sh",
            "async": true
          }
        ],
        "matcher": "permission_prompt"
      }
    ]
  }
}

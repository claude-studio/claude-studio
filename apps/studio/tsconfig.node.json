{
  "extends": "@repo/typescript-config/electron-main.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "outDir": "out",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*"],
  "exclude": ["node_modules"]
}
